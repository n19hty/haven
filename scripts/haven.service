[Unit]
Description=Haven Gaming Server
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/haven/packages/server
ExecStart=/home/pi/haven/packages/server/.venv/bin/python app.py
Restart=always
RestartSec=3
Environment=PORT=3001
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
